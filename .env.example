# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Google AI (Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key # should not go in preview because of lack of misuse cases control

# Niubiz Payment Gateway
NIUBIZ_MERCHANT_ID=your-merchant-id
NIUBIZ_API_USERNAME=your@email.com
NIUBIZ_API_PASS=your-password
NIUBIZ_SECURITY_URL=https://apisandbox.vnforappstest.com/api.security/v1/security
NIUBIZ_SESSION_URL=https://apisandbox.vnforappstest.com/api.ecommerce/v2/ecommerce/token/session

# App
NEXT_PUBLIC_APP_ENVIRONMENT=DEV  # DEV or PRD
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Test card for sandbox prefill — leave empty in PRD with real payment
NEXT_PUBLIC_TEST_CARD_NUMBER=
NEXT_PUBLIC_TEST_CARD_EXP_DATE=
NEXT_PUBLIC_TEST_CRD_CVV=
NEXT_PUBLIC_CHAT_MAX_TURNS=20
NEXT_PUBLIC_RESERVATION_TTL_SECONDS=300
CHAT_MAX_CONTEXT_MESSAGES=30

# Bot A/B variant — a named snapshot of the full bot config: model + prompt + tools + temperature.
# Bump the patch suffix whenever any component changes.
# See src/infrastructure/bot/BotVariantRegistry.ts for variant definitions.
#   av0.1 → baseline  (gemini-2.0-flash)
#   av0.2 → baseline v2 (gemini-2.0-flash-lite)
#   bv0.1 → challenger (gemini-2.5-flash)
#   bv0.2 → challenger v2 (gemini-2.5-flash-lite-preview)
# Omit or leave empty to use av0.1
CHAT_BOT_VARIANT=av0.1
